{%- doc -%}
  Renders a visual-only list of color swatches for product cards.
  Shows up to 5 colors and a +N counter when more colors exist.

  @param {object} product_resource - The product object.
  @param {number} [limit] - Maximum swatches to show.
{%- enddoc -%}

{%- liquid
  assign swatch_limit = limit | default: 5
  assign color_option = blank

  for product_option in product_resource.options_with_values
    assign option_name_downcase = product_option.name | downcase
    if option_name_downcase contains 'color' or option_name_downcase contains 'colour'
      assign color_option = product_option
      break
    endif
  endfor
-%}

{%- if color_option != blank and color_option.values.size > 0 -%}
  {%- liquid
    assign color_count = color_option.values.size
    assign extra_colors_count = color_count | minus: swatch_limit
    assign variant_option_key = 'option' | append: color_option.position
  -%}

  <div class="product-card-color-swatches" aria-label="Colores disponibles">
    {%- for product_option_value in color_option.values limit: swatch_limit -%}
      {%- liquid
        assign color_label = product_option_value.name | default: product_option_value
        assign swatch_bg = blank
        assign swatch_img = blank
        assign matched_variant = blank

        for variant in product_resource.variants
          if variant[variant_option_key] == product_option_value
            assign matched_variant = variant
            break
          endif
        endfor

        if matched_variant and matched_variant.metafields.custom.color.value
          assign color_meta = matched_variant.metafields.custom.color.value

          if color_meta.image != blank
            assign swatch_img = color_meta.image
          elsif color_meta.color != blank
            assign swatch_bg = color_meta.color
          endif
        endif
      -%}

      <span
        class="product-card-color-swatches__item{% if swatch_bg == blank and swatch_img == blank %} product-card-color-swatches__item--empty{% endif %}"
        title="{{ color_label | escape }}"
        aria-label="{{ color_label | escape }}"
        style="
          {% if swatch_img != blank %}
            --product-card-swatch-background: url({{ swatch_img | image_url: width: 80 }});
            --product-card-swatch-size: cover;
            --product-card-swatch-position: center;
          {% elsif swatch_bg != blank %}
            --product-card-swatch-background: {{ swatch_bg }};
          {% endif %}
        "
      ></span>
    {%- endfor -%}

    {%- if extra_colors_count > 0 -%}
      <span class="product-card-color-swatches__more" aria-label="{{ extra_colors_count }} colores adicionales">
        +{{ extra_colors_count }}
      </span>
    {%- endif -%}
  </div>
{%- endif -%}