<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style housedecor-gallery-grid"
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'border-override', settings: section.settings %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="housedecor-gallery-grid__inner">
    {% if section.settings.caption != blank or section.settings.heading != blank or section.settings.description != blank %}
      <div class="housedecor-gallery-grid__header">
        {% if section.settings.caption != blank %}
          <div class="text-block h6 housedecor-gallery-grid__caption">
            <p>{{ section.settings.caption }}</p>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="text-block h2 housedecor-gallery-grid__heading">
            <h2>{{ section.settings.heading }}</h2>
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="text-block paragraph rte housedecor-gallery-grid__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="housedecor-gallery-grid__list" id="GalleryGrid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="housedecor-gallery-grid__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <button
              type="button"
              class="housedecor-gallery-grid__trigger"
              data-gallery-index="{{ forloop.index0 }}"
              data-gallery-src="{{ block.settings.image | image_url: width: 2400 }}"
              data-gallery-alt="{{ block.settings.image.alt | escape }}"
              aria-label="Abrir imagen {{ forloop.index }}"
            >
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  class: 'housedecor-gallery-grid__image'
              }}
            </button>
          {% else %}
            {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-image' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="housedecor-gallery-lightbox" id="GalleryLightbox-{{ section.id }}" hidden>
    <div class="housedecor-gallery-lightbox__backdrop" data-gallery-close></div>

    <div
      class="housedecor-gallery-lightbox__dialog"
      role="dialog"
      aria-modal="true"
      aria-label="Galería ampliada"
    >
      <button
        type="button"
        class="housedecor-gallery-lightbox__close"
        aria-label="Cerrar galería"
        data-gallery-close
      >
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>

      <button
        type="button"
        class="housedecor-gallery-lightbox__nav housedecor-gallery-lightbox__nav--prev"
        aria-label="Imagen anterior"
        data-gallery-prev
      >
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="housedecor-gallery-lightbox__stage">
        <div class="housedecor-gallery-lightbox__media-wrap">
          <img
            class="housedecor-gallery-lightbox__image"
            id="GalleryLightboxImage-{{ section.id }}"
            src=""
            alt=""
            height="100%"
            width="100%"
          >
        </div>
      </div>

      <button
        type="button"
        class="housedecor-gallery-lightbox__nav housedecor-gallery-lightbox__nav--next"
        aria-label="Imagen siguiente"
        data-gallery-next
      >
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    const sectionId = {{ section.id | json }};
    const gallery = document.getElementById(`GalleryGrid-${sectionId}`);
    const lightbox = document.getElementById(`GalleryLightbox-${sectionId}`);
    const lightboxImage = document.getElementById(`GalleryLightboxImage-${sectionId}`);

    if (!gallery || !lightbox || !lightboxImage) return;

    const triggers = Array.from(gallery.querySelectorAll('[data-gallery-index]'));
    if (!triggers.length) return;

    let currentIndex = 0;

    function getItem(index) {
      return triggers[index] || null;
    }

    function openLightbox(index) {
      const item = getItem(index);
      if (!item) return;

      currentIndex = index;

      lightboxImage.src = item.getAttribute('data-gallery-src') || '';
      lightboxImage.alt = item.getAttribute('data-gallery-alt') || '';

      lightbox.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      document.body.classList.add('gallery-lightbox-open');
    }

    function closeLightbox() {
      lightbox.hidden = true;
      lightboxImage.src = '';
      lightboxImage.alt = '';
      document.documentElement.style.overflow = '';
      document.body.classList.remove('gallery-lightbox-open');
    }

    function showPrev() {
      currentIndex = currentIndex <= 0 ? triggers.length - 1 : currentIndex - 1;
      openLightbox(currentIndex);
    }

    function showNext() {
      currentIndex = currentIndex >= triggers.length - 1 ? 0 : currentIndex + 1;
      openLightbox(currentIndex);
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => openLightbox(index));
    });

    lightbox.addEventListener('click', (event) => {
      const closeTarget = event.target.closest('[data-gallery-close]');
      const prevTarget = event.target.closest('[data-gallery-prev]');
      const nextTarget = event.target.closest('[data-gallery-next]');

      if (closeTarget) closeLightbox();
      if (prevTarget) showPrev();
      if (nextTarget) showNext();
    });

    document.addEventListener('keydown', (event) => {
      if (lightbox.hidden) return;

      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowLeft') showPrev();
      if (event.key === 'ArrowRight') showNext();
    });
  })();
</script>

{% stylesheet %}
  .housedecor-gallery-grid__inner {
    width: 100%;
  }

  .housedecor-gallery-grid__header {
    text-align: center;
    max-width: 72rem;
    margin-inline: auto;
    margin-bottom: var(--margin-xl);
  }

  .housedecor-gallery-grid__heading h2 {
    text-align: center;
  }

  .housedecor-gallery-grid__caption,
  .housedecor-gallery-grid__heading,
  .housedecor-gallery-grid__description {
    text-align: center;
    margin-bottom: var(--margin-md);
  }

  .housedecor-gallery-grid__caption :is(p, h1, h2, h3, h4, h5, h6),
  .housedecor-gallery-grid__heading :is(p, h1, h2, h3, h4, h5, h6),
  .housedecor-gallery-grid__description :is(p, h1, h2, h3, h4, h5, h6) {
    margin: 0;
  }

  .housedecor-gallery-grid__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-md);
  }

  @media screen and (min-width: 750px) {
    .housedecor-gallery-grid__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .housedecor-gallery-grid__item {
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-images);
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .housedecor-gallery-grid__trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .housedecor-gallery-grid__image,
  .housedecor-gallery-grid__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: block;
  }

  .housedecor-gallery-grid__image {
    object-fit: cover;
    object-position: center;
    transition: transform var(--animation-speed, 0.25s) ease;
  }

  .housedecor-gallery-grid__trigger:hover .housedecor-gallery-grid__image {
    transform: scale(1.03);
  }

  .housedecor-gallery-grid__placeholder {
    background: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .housedecor-gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
  }

  .housedecor-gallery-lightbox[hidden] {
    display: none;
  }

  .housedecor-gallery-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.84);
  }

  .housedecor-gallery-lightbox__dialog {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100dvh;
    display: grid;
    grid-template-columns: minmax(56px, 72px) minmax(0, 1fr) minmax(56px, 72px);
    align-items: center;
    gap: 0;
    padding: clamp(16px, 2vw, 28px);
    box-sizing: border-box;
  }

  .housedecor-gallery-lightbox__stage {
    width: 100%;
    height: 100%;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 2vw, 28px);
    box-sizing: border-box;
  }

  .housedecor-gallery-lightbox__media-wrap {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 10px;
  }

  .housedecor-gallery-lightbox__image {
      width: auto;
      height: 100%;
      max-width: 100%;
      max-height: 700px;
      margin: 0 auto;
      display: block;
      object-fit: contain;
  }

  .housedecor-gallery-lightbox__close,
  .housedecor-gallery-lightbox__nav {
    border: 0;
    background: rgb(255 255 255 / 0.14);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(4px);
  }

  .housedecor-gallery-lightbox__close:hover,
  .housedecor-gallery-lightbox__nav:hover {
    background: rgb(255 255 255 / 0.24);
  }

  .housedecor-gallery-lightbox__nav {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    align-self: center;
    justify-self: center;
    position: relative;
    z-index: 2;
  }

  .housedecor-gallery-lightbox__close {
    position: absolute;
    top: clamp(14px, 2vw, 24px);
    right: clamp(14px, 2vw, 24px);
    width: 56px;
    height: 56px;
    border-radius: 999px;
    z-index: 3;
  }

  .housedecor-gallery-lightbox__close svg,
  .housedecor-gallery-lightbox__nav svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .housedecor-gallery-lightbox__dialog {
      grid-template-columns: 1fr;
      padding: 12px;
    }

    .housedecor-gallery-lightbox__stage {
      padding: 48px 0;
    }

    .housedecor-gallery-lightbox__media-wrap {
      width: 100%;
      height: min(74dvh, 74vh);
    }

    .housedecor-gallery-lightbox__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 48px;
      height: 48px;
    }

    .housedecor-gallery-lightbox__nav--prev {
      left: 10px;
    }

    .housedecor-gallery-lightbox__nav--next {
      right: 10px;
    }

    .housedecor-gallery-lightbox__close {
      width: 48px;
      height: 48px;
      top: 10px;
      right: 10px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Galería imágenes",
  "tag": "section",
  "class": "section-housedecor-gallery-grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Proyectos recientes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Proyectos recientes"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Cada detalle cuenta la historia de nuestro oficio"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Imagen",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galería imágenes",
      "category": "Custom",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}