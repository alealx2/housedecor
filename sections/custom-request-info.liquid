<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style housedecor-quote-contact"
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'border-override', settings: section.settings %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="housedecor-quote-contact__grid">
    <div class="housedecor-quote-contact__info">
      <div class="housedecor-quote-contact__info-inner">
        {% if section.settings.caption != blank %}
          <div class="text-block h6 housedecor-quote-contact__caption">
            <p>{{ section.settings.caption }}</p>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="text-block h2 housedecor-quote-contact__heading">
            <h2>{{ section.settings.heading }}</h2>
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="text-block paragraph rte housedecor-quote-contact__description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        <div class="housedecor-quote-contact__details">
          {% if section.settings.email != blank %}
            <div class="housedecor-quote-contact__detail">
              <span class="housedecor-quote-contact__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M4 6H20V18H4V6Z" stroke="currentColor" stroke-width="1.6"/>
                  <path d="M4 7L12 13L20 7" stroke="currentColor" stroke-width="1.6"/>
                </svg>
              </span>
              <span class="text-block paragraph">
                <p>{{ section.settings.email }}</p>
              </span>
            </div>
          {% endif %}

          {% if section.settings.phone != blank %}
            <div class="housedecor-quote-contact__detail">
              <span class="housedecor-quote-contact__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M7.5 4.5C7.9 4.1 8.5 4 9 4.2L11.2 5.1C11.8 5.3 12.1 5.9 12 6.5L11.6 8.7C11.5 9.1 11.6 9.5 11.9 9.8L14.2 12.1C14.5 12.4 14.9 12.5 15.3 12.4L17.5 12C18.1 11.9 18.7 12.2 18.9 12.8L19.8 15C20 15.5 19.9 16.1 19.5 16.5L18.2 17.8C17.4 18.6 16.2 18.9 15.1 18.6C12.3 17.7 9.7 16.1 7.6 14C5.5 11.9 3.9 9.3 3 6.5C2.7 5.4 3 4.2 3.8 3.4L5.1 2.1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="text-block paragraph">
                <p>{{ section.settings.phone }}</p>
              </span>
            </div>
          {% endif %}

          {% if section.settings.address != blank %}
            <div class="housedecor-quote-contact__detail">
              <span class="housedecor-quote-contact__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M12 21C12 21 18 14.8 18 10C18 6.7 15.3 4 12 4C8.7 4 6 6.7 6 10C6 14.8 12 21 12 21Z" stroke="currentColor" stroke-width="1.6"/>
                  <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"/>
                </svg>
              </span>
              <span class="text-block paragraph">
                <p>{{ section.settings.address }}</p>
              </span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="housedecor-quote-contact__form">
      <div class="housedecor-quote-contact__form-inner">
        {% render 'custom-quote-form', section: section %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .housedecor-quote-contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-xl);
  }

  @media screen and (min-width: 990px) {
    .housedecor-quote-contact__grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.35fr);
      gap: clamp(3rem, 5vw, 8rem);
      align-items: start;
    }
  }

  .housedecor-quote-contact__info-inner,
  .housedecor-quote-contact__form-inner {
    width: 100%;
  }

  .housedecor-quote-contact__caption,
  .housedecor-quote-contact__heading,
  .housedecor-quote-contact__description {
    margin-bottom: var(--margin-lg);
  }

  .housedecor-quote-contact__heading :is(h1, h2, h3, h4, h5, h6),
  .housedecor-quote-contact__caption :is(h1, h2, h3, h4, h5, h6, p),
  .housedecor-quote-contact__description :is(h1, h2, h3, h4, h5, h6, p) {
    margin: 0;
  }

  .housedecor-quote-contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    margin-top: var(--margin-xl);
  }

  .housedecor-quote-contact__detail {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .housedecor-quote-contact__detail p {
    margin: 0;
  }

  .housedecor-quote-contact__icon {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 2rem;
  }

  .housedecor-quote-contact__icon svg {
    width: 2rem;
    height: 2rem;
  }

  .housedecor-quote-contact__form {
    min-width: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Solicita información",
  "tag": "section",
  "class": "section-housedecor-quote-contact",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Cotización"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Solicite su presupuesto"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Cuéntenos qué necesita y recibirá una cotización personalizada"
    },
    {
      "type": "header",
      "content": "Datos de contacto"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Correo",
      "default": "correo@ejemplo.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Teléfono",
      "default": "+56 9 7232 7157"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Dirección",
      "default": "Ñuble 1034, Santiago Chile"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Solicita información",
      "category": "Custom"
    }
  ]
}
{% endschema %}